# API Configuration
# Base URL only (do not include trailing /api) because API modules call paths like /api/products
NEXT_PUBLIC_API_URL=http://localhost:8000

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-change-in-production
AUTH_URL=http://localhost:3000
AUTH_SECRET=your-secret-key-here-change-in-production

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Application
NODE_ENV=development

# Dev tools (optional)
# Set to true to load React Query Devtools in the browser (can slow down dev HMR/compilation)
NEXT_PUBLIC_ENABLE_RQ_DEVTOOLS=false
